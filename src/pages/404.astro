---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found">
  <main class="min-h-dvh flex items-center justify-center px-6 text-center">
    <div>
      <h1 class="text-2xl font-semibold">404</h1>
      <p class="text-fg-subtle mt-2">Page not found.</p>
      <a href="/" class="mt-6 inline-block px-4 py-2 rounded-full bg-accent text-white no-underline">
        Home
      </a>
    </div>
  </main>
</BaseLayout>
