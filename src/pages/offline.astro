---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Offline">
  <main class="min-h-dvh flex items-center justify-center px-6 text-center">
    <div>
      <h1 class="text-2xl font-semibold">Offline</h1>
      <p class="text-fg-subtle mt-2">This page is not cached. Reconnect and reload.</p>
      <button
        type="button"
        onclick="location.reload()"
        class="mt-6 px-4 py-2 rounded-full bg-accent text-white"
      >
        Reload
      </button>
    </div>
  </main>
</BaseLayout>
