---
import BranchLayout from '@/layouts/BranchLayout.astro';
import branchesData from '@/data/branches.json';
import DocsTree from '@/components/DocsTree';

export function getStaticPaths() {
  return branchesData.branches.map((b) => ({ params: { branch: b.slug } }));
}

const { branch: branchSlug } = Astro.params;
const branch = branchesData.branches.find((b) => b.slug === branchSlug);
if (!branch) throw new Error(`Branch not found: ${branchSlug}`);

const docs = branch.docs.map((d) => ({
  path: d.path,
  filename: d.filename,
  category: d.category,
  lastModified: d.lastModified,
}));
---

<BranchLayout title={`Docs — ${branch.name}`} branchSlug={branchSlug!} tab="docs">
  <main class="min-h-dvh">
    <header class="px-4 pt-3 pb-2">
      <h1 class="text-lg font-semibold">Docs</h1>
      <p class="text-xs text-fg-subtle mt-0.5">{docs.length} files</p>
    </header>
    <DocsTree client:load branchSlug={branchSlug!} docs={docs} />
  </main>
</BranchLayout>
