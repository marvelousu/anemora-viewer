{
  "name": "anemora-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mobile viewer (PWA) for the Anemora project",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/setup-content.mjs && node scripts/setup-r2-images.mjs && node scripts/generate-icons.mjs && astro build && pagefind --site dist --output-subdir pagefind",
    "build:fast": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.2.0",
    "@astrojs/tailwind": "^5.1.4",
    "@tailwindcss/typography": "^0.5.19",
    "@vite-pwa/astro": "^0.5.0",
    "astro": "^5.1.0",
    "framer-motion": "^11.18.0",
    "gray-matter": "^4.0.3",
    "photoswipe": "^5.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remark-gfm": "^4.0.0",
    "remark-wiki-link": "^2.0.1",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "workbox-window": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "pagefind": "^1.2.0"
  }
}
