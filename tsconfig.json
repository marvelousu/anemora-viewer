{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"baseUrl": ".",
		"paths": {
			"@/*": [
				"src/*"
			]
		}
	},
	"include": [
		"src",
		"scripts",
		".astro/types.d.ts",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist",
		"node_modules",
		"content"
	]
}